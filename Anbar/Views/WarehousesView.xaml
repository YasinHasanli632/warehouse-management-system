<UserControl x:Class="Anbar.Views.WarehousesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7FB">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="BtnBlue" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Anbarlar" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Anbarları yarat, düzəlt və rəflər üçün əsas anbar seçimini hazırla"
                               Foreground="#64748B"
                               FontSize="13"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <TextBox x:Name="SearchText"
                         Grid.Column="1"
                         Style="{StaticResource InputStyle}"
                         TextChanged="SearchText_TextChanged"/>

                <Button Grid.Column="3"
                        Content="Yenilə"
                        Height="38"
                        Padding="16,0"
                        Background="#EAF1FF"
                        Foreground="#1E3A8A"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Click="Refresh_Click"/>

                <Button Grid.Column="5"
                        Content="+ Yeni anbar"
                        Width="130"
                        Style="{StaticResource BtnBlue}"
                        Click="NewWarehouse_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="410"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="18">
                <DataGrid x:Name="WarehousesGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeight="38"
                          SelectionChanged="WarehousesGrid_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="120"/>
                        <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="180"/>
                        <DataGridTextColumn Header="Ünvan" Binding="{Binding Address}" Width="*"/>
                        <DataGridTextColumn Header="Qeyd" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Yaradılma tarixi" Binding="{Binding CreatedAtText}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel>
                    <TextBlock x:Name="FormTitleText"
                               Text="Yeni anbar"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Anbar adı" Foreground="#475569" FontWeight="SemiBold"/>
                    <TextBox x:Name="NameText"
                             Style="{StaticResource InputStyle}"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Anbar kodu" Foreground="#475569" FontWeight="SemiBold"/>
                    <TextBox x:Name="CodeText"
                             Style="{StaticResource InputStyle}"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Ünvan" Foreground="#475569" FontWeight="SemiBold"/>
                    <TextBox x:Name="AddressText"
                             Style="{StaticResource InputStyle}"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Qeyd" Foreground="#475569" FontWeight="SemiBold"/>
                    <TextBox x:Name="DescriptionText"
                             Height="90"
                             Padding="10"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             Margin="0,6,0,16"/>

                    <Button x:Name="SaveButton"
                            Content="Yadda saxla"
                            Style="{StaticResource BtnBlue}"
                            Click="SaveButton_Click"/>

                    <Button Content="Əsas Anbar yarat"
                            Height="38"
                            Margin="0,10,0,0"
                            Background="#ECFDF5"
                            Foreground="#047857"
                            BorderBrush="#A7F3D0"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Click="CreateDefaultWarehouse_Click"/>

                    <Button Content="Formanı təmizlə"
                            Height="38"
                            Margin="0,10,0,0"
                            Background="#EAF1FF"
                            Foreground="#1E3A8A"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Click="ClearButton_Click"/>

                    <Button x:Name="DeactivateButton"
                            Content="Anbarı passiv et"
                            Height="38"
                            Margin="0,10,0,0"
                            Background="#F8FAFC"
                            Foreground="#475569"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            IsEnabled="False"
                            Click="DeactivateButton_Click"/>

                    <Border Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,14,0,0">
                        <TextBlock x:Name="MessageText"
                                   Text="Yeni anbar əlavə edə bilərsiniz."
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>