<UserControl x:Class="Anbar.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7FB">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SoftButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#EAF1FF"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Style="{StaticResource CardStyle}" Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Müştərilər"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>

                    <TextBlock Text="Mal çıxışı qaimələrində istifadə olunan müştəri məlumatları"
                               Foreground="#64748B"
                               FontSize="13"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <TextBox x:Name="SearchText"
                         Grid.Column="1"
                         Height="38"
                         VerticalContentAlignment="Center"
                         Padding="12,0"
                         BorderBrush="#CBD5E1"
                         BorderThickness="1"
                         TextChanged="SearchText_TextChanged"/>

                <Button Grid.Column="3"
                        Content="Yenilə"
                        Style="{StaticResource SoftButtonStyle}"
                        Click="RefreshButton_Click"/>

                <Button Grid.Column="5"
                        Content="+ Yeni müştəri"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="NewCustomer_Click"/>
            </Grid>
        </Border>

        <!-- Stats -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Ümumi Müştəri" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalCustomersText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Borclu Müştəri" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DebtCustomersText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#DC2626"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Ümumi Borc" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalDebtText" Text="0.00 AZN" FontSize="25" FontWeight="Bold" Foreground="#B45309"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource CardStyle}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Kredit Limiti" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalCreditText" Text="0.00 AZN" FontSize="25" FontWeight="Bold" Foreground="#2563EB"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="430"/>
            </Grid.ColumnDefinitions>

            <!-- List -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Müştəri siyahısı"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"/>

                        <Border Grid.Column="1"
                                Background="#EFF6FF"
                                CornerRadius="12"
                                Padding="12,5">
                            <TextBlock x:Name="TotalCountText"
                                       Text="0 qeyd"
                                       Foreground="#1E3A8A"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <DataGrid x:Name="CustomersGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="White"
                              BorderThickness="0"
                              RowHeight="38"
                              SelectionChanged="CustomersGrid_SelectionChanged">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="160"/>
                            <DataGridTextColumn Header="Şirkət" Binding="{Binding CompanyName}" Width="160"/>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="125"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
                            <DataGridTextColumn Header="VÖEN" Binding="{Binding Voen}" Width="115"/>
                            <DataGridTextColumn Header="Borc" Binding="{Binding DebtAmount}" Width="90"/>
                            <DataGridTextColumn Header="Limit" Binding="{Binding CreditLimit}" Width="90"/>
                            <DataGridTextColumn Header="Valyuta" Binding="{Binding Currency}" Width="80"/>
                            <DataGridTextColumn Header="Ödəniş" Binding="{Binding PaymentType}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Form / Detail -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock x:Name="FormTitleText"
                                   Text="Yeni müştəri"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Müştəri adı *" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="NameText" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Şirkət adı" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="CompanyNameText" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Telefon" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="PhoneText" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="EmailText" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Ünvan" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="AddressText" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="VÖEN" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="VoenText" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Bank adı" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="BankNameText" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Bank hesabı" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="BankAccountText" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Valyuta" Style="{StaticResource LabelStyle}"/>
                                <ComboBox x:Name="CurrencyCombo" Style="{StaticResource ComboStyle}" Margin="0,0,0,12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ödəniş növü" Style="{StaticResource LabelStyle}"/>
                                <ComboBox x:Name="PaymentTypeCombo" Style="{StaticResource ComboStyle}" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Kredit limiti" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="CreditLimitText" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Cari borc" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="DebtAmountText"
                                         Style="{StaticResource InputStyle}"
                                         IsReadOnly="True"
                                         Background="#F8FAFC"
                                         Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Qeyd" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="NoteText"
                                 Height="82"
                                 Padding="10"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 BorderBrush="#CBD5E1"
                                 BorderThickness="1"
                                 Background="White"
                                 Margin="0,0,0,16"/>

                        <Button x:Name="SaveButton"
                                Content="Yadda saxla"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveButton_Click"/>

                        <Button Content="Formanı təmizlə"
                                Style="{StaticResource SoftButtonStyle}"
                                Margin="0,10,0,0"
                                Click="ClearButton_Click"/>

                        <Button x:Name="DeactivateButton"
                                Content="Müştərini passiv et"
                                Style="{StaticResource DangerButtonStyle}"
                                Margin="0,10,0,0"
                                IsEnabled="False"
                                Click="DeactivateButton_Click"/>

                        <Border Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12"
                                Margin="0,14,0,0">

                            <TextBlock x:Name="MessageText"
                                       Text="Yeni müştəri əlavə edə bilərsiniz."
                                       Foreground="#64748B"
                                       TextWrapping="Wrap"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>