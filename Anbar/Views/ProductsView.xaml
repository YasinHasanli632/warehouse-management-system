<UserControl x:Class="Anbar.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FB">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#0F5BD7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="LightButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="RowHeight" Value="44"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="☰"
                    Width="42"
                    Height="38"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="20"
                    Foreground="#334155"/>

            <TextBlock Grid.Column="2"
                       Text="Məhsullar"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#0F172A"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Filter card -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorder}"
                Padding="18">
            <StackPanel>
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Məhsul siyahısı"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#111827"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="+  Yeni Məhsul Əlavə Et"
                            Style="{StaticResource PrimaryButton}"
                            Click="NewProduct_Click"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchText"
                             Grid.Column="0"
                             TextChanged="SearchText_TextChanged"
                             ToolTip="Məhsul adı, kod və ya barkod üzrə axtar"
                             Text=""/>

                    <ComboBox x:Name="CategoryFilterCombo"
                              Grid.Column="2"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectionChanged="Filter_Changed"/>

                    <ComboBox x:Name="UnitFilterCombo"
                              Grid.Column="4"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectionChanged="Filter_Changed"/>

                    <ComboBox x:Name="StatusFilterCombo"
                              Grid.Column="6"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectionChanged="Filter_Changed"/>

                    <DatePicker x:Name="DateFromPicker"
                                Grid.Column="8"
                                SelectedDateChanged="DateFilter_Changed"/>

                    <TextBlock Grid.Column="9"
                               Text="-"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="#64748B"/>

                    <DatePicker x:Name="DateToPicker"
                                Grid.Column="10"
                                SelectedDateChanged="DateFilter_Changed"/>

                    <Button Grid.Column="12"
                            Content="Təmizlə"
                            Style="{StaticResource LightButton}"
                            Click="ClearFilters_Click"/>

                    <Button Grid.Column="14"
                            Content="Axtar"
                            Style="{StaticResource PrimaryButton}"
                            Click="SearchButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Table card -->
        <Border Grid.Row="4"
                Style="{StaticResource CardBorder}"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="Excel-ə ixrac"
                            Style="{StaticResource LightButton}"
                            Click="ExportExcel_Click"/>

                    <Button Grid.Column="2"
                            Content="PDF-ə ixrac"
                            Style="{StaticResource LightButton}"
                            Click="ExportPdf_Click"/>

                    <Button Grid.Column="4"
                            Content="Sütunlar"
                            Style="{StaticResource LightButton}"/>

                    <TextBlock x:Name="TotalCountText"
                               Grid.Column="6"
                               Text="Cəmi: 0 məhsul"
                               VerticalAlignment="Center"
                               Foreground="#111827"/>

                    <Button Grid.Column="8"
                            Content="⟳"
                            Width="38"
                            Height="36"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="18"
                            Foreground="#334155"
                            Click="Refresh_Click"/>
                </Grid>

                <DataGrid x:Name="ProductsGrid"
                          Grid.Row="2"
                          ItemsSource="{Binding}"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding RowNo}" Width="50"/>
                        <DataGridTextColumn Header="Məhsul Kodu" Binding="{Binding Code}" Width="130"/>
                        <DataGridTextColumn Header="Barkod" Binding="{Binding Barcode}" Width="150"/>
                        <DataGridTextColumn Header="Məhsul Adı" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Kateqoriya" Binding="{Binding CategoryName}" Width="160"/>
                        <DataGridTextColumn Header="Ölçü Vahidi" Binding="{Binding UnitName}" Width="120"/>
                        <DataGridTextColumn Header="Alış Qiyməti (AZN)" Binding="{Binding PurchasePriceText}" Width="150"/>
                        <DataGridTextColumn Header="Satış Qiyməti (AZN)" Binding="{Binding SalePriceText}" Width="150"/>
                        <DataGridTextColumn Header="Min. Stok" Binding="{Binding MinStockText}" Width="110"/>

                        <DataGridTemplateColumn Header="Status" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#DCFCE7"
                                            CornerRadius="10"
                                            Padding="10,3"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="#15803D"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Əməliyyatlar" Width="145">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="👁"
                                                Width="32"
                                                Height="28"
                                                Margin="0,0,6,0"
                                                Background="#EAF1FF"
                                                BorderThickness="0"
                                                Tag="{Binding Id}"
                                                Click="ViewProduct_Click"/>

                                        <Button Content="✎"
                                                Width="32"
                                                Height="28"
                                                Margin="0,0,6,0"
                                                Background="#FEF3C7"
                                                BorderThickness="0"
                                                Tag="{Binding Id}"
                                                Click="EditProduct_Click"/>

                                        <Button Content="🗑"
                                                Width="32"
                                                Height="28"
                                                Background="#FEE2E2"
                                                BorderThickness="0"
                                                Tag="{Binding Id}"
                                                Click="DeleteProduct_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Səhifədə göstər:"
                               VerticalAlignment="Center"
                               Foreground="#111827"/>

                    <ComboBox x:Name="PageSizeCombo"
                              Grid.Column="2"
                              SelectedIndex="0"
                              SelectionChanged="PageSizeCombo_SelectionChanged">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="25"/>
                        <ComboBoxItem Content="50"/>
                        <ComboBoxItem Content="100"/>
                    </ComboBox>

                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <Button Content="«" Width="38" Height="34" Style="{StaticResource LightButton}" Click="PrevPage_Click"/>
                        <Button x:Name="PageOneButton" Content="1" Width="38" Height="34" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}"/>
                        <Button x:Name="PageTwoButton" Content="2" Width="38" Height="34" Margin="8,0,0,0" Style="{StaticResource LightButton}"/>
                        <Button x:Name="PageThreeButton" Content="3" Width="38" Height="34" Margin="8,0,0,0" Style="{StaticResource LightButton}"/>
                        <Button Content="»" Width="38" Height="34" Margin="8,0,0,0" Style="{StaticResource LightButton}" Click="NextPage_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Bottom info -->
        <Border Grid.Row="6"
                Style="{StaticResource CardBorder}"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel Margin="20,0">
                        <TextBlock Text="👁" FontSize="22" HorizontalAlignment="Center"/>
                        <TextBlock Text="Görüntülə" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Məhsul detallarını göstər" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>

                    <StackPanel Margin="20,0">
                        <TextBlock Text="✎" FontSize="22" HorizontalAlignment="Center"/>
                        <TextBlock Text="Redaktə et" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Məhsulu redaktə et" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>

                    <StackPanel Margin="20,0">
                        <TextBlock Text="🗑" FontSize="22" HorizontalAlignment="Center"/>
                        <TextBlock Text="Sil" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Məhsulu passiv et" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="#E5E7EB"/>

                <StackPanel Grid.Column="2" Margin="24,0,0,0">
                    <TextBlock Text="Qısa izah" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Text="• Axtarış: Məhsul adı, kodu və ya barkod üzrə axtarış edir." Margin="0,0,0,5"/>
                    <TextBlock Text="• Filtrlər: Kateqoriya, ölçü vahidi, status və tarixə görə süzgəc." Margin="0,0,0,5"/>
                    <TextBlock Text="• İxrac funksiyası: Excel və PDF formatında çıxarış." Margin="0,0,0,5"/>
                    <TextBlock Text="• Sütunlar: İstifadəçi istədiyi sütunları gizlədə və göstərə bilər."/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>