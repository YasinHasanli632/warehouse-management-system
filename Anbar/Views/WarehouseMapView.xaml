<UserControl x:Class="Anbar.Views.WarehouseMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F7FAFC">

    <UserControl.Resources>

        <SolidColorBrush x:Key="PageBg" Color="#F7FAFC"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMain" Color="#111827"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#DDE6F0"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0B64D8"/>
        <SolidColorBrush x:Key="Green" Color="#16A34A"/>
        <SolidColorBrush x:Key="Yellow" Color="#F59E0B"/>
        <SolidColorBrush x:Key="Red" Color="#DC2626"/>

        <Style x:Key="TopStatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="MinWidth" Value="112"/>
        </Style>

        <Style x:Key="RightCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDE6F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="ActionButtonBlue" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Background" Value="#0B64D8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ActionButtonRed" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ActionButtonWhite" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0B64D8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F7"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#DDE6F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="{StaticResource PageBg}">

        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1">
            <Grid Margin="26,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="ANBAR XƏRİTƏSİ"
                           FontSize="17"
                           FontWeight="Black"
                           Foreground="#0B64D8"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Border Style="{StaticResource TopStatCard}" Margin="0,0,12,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Ümumi Məhsul" FontSize="11" Foreground="#334155"/>
                            <TextBlock x:Name="TotalProductCountText" Text="0" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource TopStatCard}" Margin="0,0,12,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Ümumi Rəf" FontSize="11" Foreground="#334155"/>
                            <TextBlock x:Name="TotalShelfCountText" Text="0" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource TopStatCard}" Margin="0,0,26,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Doluluq Oranı" FontSize="11" Foreground="#334155"/>
                            <TextBlock x:Name="AverageOccupancyText" Text="0%" FontSize="22" FontWeight="Black" Foreground="#16A34A" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="⚙"
                               FontSize="24"
                               Foreground="#0B64D8"
                               Margin="0,0,24,0"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="🖨"
                               FontSize="21"
                               Foreground="#334155"
                               Margin="0,0,26,0"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="20.05.2025"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Margin="0,0,24,0"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="15:30"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- MAP AREA -->
            <Border Background="White"
                    BorderBrush="#DDE6F0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Anbar xəritəsi"
                                       FontSize="24"
                                       FontWeight="Black"
                                       Foreground="#111827"/>

                            <TextBlock Text="Rəflər sıra üzrə düzülür. Seçilən rəfin detalları sağ paneldə göstərilir."
                                       FontSize="13"
                                       Foreground="#64748B"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="⟳ Yenilə"
                                Width="108"
                                Height="38"
                                Background="#0B64D8"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="Refresh_Click"/>
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ZonesPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT DETAIL -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#DDE6F0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SelectedShelfTitleText"
                               Text="SEÇİLMİŞ RƏF: -"
                               FontSize="17"
                               FontWeight="Black"
                               Foreground="#0B64D8"/>

                    <Border Grid.Row="2" Style="{StaticResource RightCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Rəf Kodu:" Foreground="#334155"/>
                            <TextBlock x:Name="ShelfCodeText" Grid.Column="1" Text="-" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1" Text="Məhsul:" Foreground="#334155"/>
                            <TextBlock x:Name="ShelfMainProductText" Grid.Row="1" Grid.Column="1" Text="-" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="2" Text="Miqdar:" Foreground="#334155"/>
                            <TextBlock x:Name="ShelfMainQuantityText" Grid.Row="2" Grid.Column="1" Text="-" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="3" Text="Doluluq:" Foreground="#334155"/>

                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <ProgressBar x:Name="ShelfOccupancyBar"
                                             Width="132"
                                             Height="14"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0"
                                             Foreground="#16A34A"
                                             Background="#E5E7EB"/>
                                <TextBlock x:Name="OccupancyText"
                                           Text="0%"
                                           Margin="10,0,0,0"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <TextBlock Grid.Row="4" Text="Son Giriş Tarixi:" Foreground="#334155"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="20.05.2025" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="5" Text="Son Çıxış Tarixi:" Foreground="#334155"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="-" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="4"
                               Text="RƏFDƏKİ MƏHSULLAR"
                               FontSize="16"
                               FontWeight="Black"
                               Foreground="#0B64D8"/>

                    <DataGrid Grid.Row="6"
                              x:Name="ShelfStockGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Məhsul" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Miqdar" Binding="{Binding QuantityWithUnit}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="46"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="46"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="+  Giriş Et"
                                Style="{StaticResource ActionButtonBlue}"/>

                        <Button Grid.Column="2"
                                Content="−  Çıxış Et"
                                Style="{StaticResource ActionButtonRed}"/>

                        <Button Grid.Row="2"
                                Grid.ColumnSpan="3"
                                Content="⇄  Transfer Et"
                                Style="{StaticResource ActionButtonWhite}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>