<UserControl x:Class="Anbar.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7FB">

    <UserControl.Resources>

        <!-- YENI: Enterprise rənglər -->
        <SolidColorBrush x:Key="PageBgBrush" Color="#F4F7FB"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1E3A8A"/>
        <SolidColorBrush x:Key="SuccessBrush2" Color="#16A34A"/>
        <SolidColorBrush x:Key="DangerBrush2" Color="#DC2626"/>
        <SolidColorBrush x:Key="WarningBrush2" Color="#F59E0B"/>

        <!-- YENI: Card stili -->
        <Style x:Key="EnterpriseCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- YENI: DataGrid enterprise görünüş -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F7"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Background="{StaticResource PageBgBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="26,22,26,24">

                <!-- YENI: Header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Dashboard"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMainBrush}"/>

                        <TextBlock Text="Anbar üzrə real stok, qaimə və rəf statistikası"
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="White"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14,9"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅"
                                       FontSize="15"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="20.05.2025"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMainBrush}"
                                       Margin="0,0,18,0"/>
                            <TextBlock Text="🕒"
                                       FontSize="15"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="15:30"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMainBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- YENI: KPI kartlar -->
                <UniformGrid Columns="4" Margin="0,0,0,18">

                    <Border Style="{StaticResource EnterpriseCard}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="52"
                                    Height="52"
                                    CornerRadius="14"
                                    Background="#DBEAFE"
                                    VerticalAlignment="Top">
                                <TextBlock Text="📦"
                                           FontSize="25"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Ümumi Məhsul"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13"/>
                                <TextBlock x:Name="TotalProductsText"
                                           Text="0"
                                           FontSize="31"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextMainBrush}"
                                           Margin="0,2,0,0"/>
                                <TextBlock Text="Real stokda aktiv məhsullar"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource EnterpriseCard}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="52"
                                    Height="52"
                                    CornerRadius="14"
                                    Background="#DCFCE7"
                                    VerticalAlignment="Top">
                                <TextBlock Text="▦"
                                           FontSize="28"
                                           Foreground="{StaticResource SuccessBrush2}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Ümumi Rəf"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13"/>
                                <TextBlock x:Name="TotalShelvesText"
                                           Text="0"
                                           FontSize="31"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextMainBrush}"
                                           Margin="0,2,0,0"/>
                                <TextBlock Text="Aktiv rəflərin sayı"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource EnterpriseCard}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="52"
                                    Height="52"
                                    CornerRadius="14"
                                    Background="#F3E8FF"
                                    VerticalAlignment="Top">
                                <TextBlock Text="◔"
                                           FontSize="30"
                                           Foreground="#7C3AED"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Doluluq Oranı"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13"/>
                                <TextBlock x:Name="OccupancyText"
                                           Text="0%"
                                           FontSize="31"
                                           FontWeight="Bold"
                                           Foreground="#7C3AED"
                                           Margin="0,2,0,0"/>
                                <TextBlock Text="Anbar doluluq faizi"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource EnterpriseCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="52"
                                    Height="52"
                                    CornerRadius="14"
                                    Background="#FEE2E2"
                                    VerticalAlignment="Top">
                                <TextBlock Text="⚠"
                                           FontSize="26"
                                           Foreground="{StaticResource DangerBrush2}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Kritik Stok"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13"/>
                                <TextBlock x:Name="CriticalStockText"
                                           Text="0"
                                           FontSize="31"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource DangerBrush2}"
                                           Margin="0,2,0,0"/>
                                <TextBlock Text="Minimumdan aşağı məhsullar"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- YENI: Orta hissə -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.15*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource EnterpriseCard}"
                            Margin="0,0,14,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34"
                                            Height="34"
                                            Background="#EFF6FF"
                                            CornerRadius="10"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="☷"
                                                   FontSize="18"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="Son Hərəkətlər"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextMainBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <DataGrid x:Name="RecentMovementsGrid" Height="268">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tarix"
                                                        Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                                        Width="155"/>
                                    <DataGridTextColumn Header="Əməliyyat"
                                                        Binding="{Binding MovementType}"
                                                        Width="125"/>
                                    <DataGridTextColumn Header="Məhsul"
                                                        Binding="{Binding Product.Name}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="Miqdar"
                                                        Binding="{Binding Quantity}"
                                                        Width="105"/>
                                    <DataGridTextColumn Header="Qaimə"
                                                        Binding="{Binding Invoice.InvoiceNumber}"
                                                        Width="155"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource EnterpriseCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34"
                                            Height="34"
                                            Background="#FEE2E2"
                                            CornerRadius="10"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="⚠"
                                                   FontSize="17"
                                                   Foreground="{StaticResource DangerBrush2}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="Kritik Stoklar"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextMainBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <DataGrid x:Name="CriticalStocksGrid" Height="268">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Məhsul"
                                                        Binding="{Binding ProductName}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="Qalıq"
                                                        Binding="{Binding TotalQuantity}"
                                                        Width="95"/>
                                    <DataGridTextColumn Header="Min."
                                                        Binding="{Binding MinStockQuantity}"
                                                        Width="95"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- YENI: Stok xülasəsi -->
                <Border Style="{StaticResource EnterpriseCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="34"
                                        Height="34"
                                        Background="#EFF6FF"
                                        CornerRadius="10"
                                        Margin="0,0,10,0">
                                    <TextBlock Text="↔"
                                               FontSize="18"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="Stok Xülasəsi"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextMainBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <DataGrid x:Name="StockSummaryGrid" Height="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kod"
                                                    Binding="{Binding ProductCode}"
                                                    Width="125"/>
                                <DataGridTextColumn Header="Məhsul"
                                                    Binding="{Binding ProductName}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Kateqoriya"
                                                    Binding="{Binding CategoryName}"
                                                    Width="180"/>
                                <DataGridTextColumn Header="Ümumi Miqdar"
                                                    Binding="{Binding TotalQuantity}"
                                                    Width="135"/>
                                <DataGridTextColumn Header="Ölçü"
                                                    Binding="{Binding Unit}"
                                                    Width="95"/>
                                <DataGridTextColumn Header="Rəf Sayı"
                                                    Binding="{Binding ShelfCount}"
                                                    Width="95"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>