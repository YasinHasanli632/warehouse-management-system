<UserControl x:Class="Anbar.Views.ProductAddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FB">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#DDE3EA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0052CC"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="BlueButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#0F5BD7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#FFF1F2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel>
                        <TextBlock Text="Məhsullar  >  Yeni Məhsul Əlavə Et"
                                   Foreground="#64748B"
                                   FontSize="13"/>

                        <TextBlock x:Name="PageTitleText"
                                   Text="Yeni Məhsul Əlavə Et"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <Button Content="✕  Bağla"
                            HorizontalAlignment="Right"
                            Width="104"
                            Height="36"
                            Background="White"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            Foreground="#334155"
                            Click="Close_Click"/>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <TextBlock Text="1. Əsas Məlumatlar" Style="{StaticResource SectionTitle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Məhsul adı *" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="NameText"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Məhsul kodu *" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="CodeText"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Barkod" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="BarcodeText"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Ana kateqoriya *" Style="{StaticResource Label}"/>
                                    <ComboBox x:Name="MainCategoryCombo"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectionChanged="MainCategoryCombo_SelectionChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Alt kateqoriya" Style="{StaticResource Label}"/>
                                    <ComboBox x:Name="SubCategoryCombo"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              IsEnabled="False"
                                              SelectionChanged="SubCategoryCombo_SelectionChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Ölçü vahidi *" Style="{StaticResource Label}"/>
                                    <ComboBox x:Name="UnitCombo"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Status" Style="{StaticResource Label}"/>
                                    <ComboBox x:Name="StatusCombo"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Təsvir" Style="{StaticResource Label}" Margin="0,12,0,5"/>
                            <TextBox x:Name="DescriptionText"
                                     Height="58"
                                     Padding="10"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <TextBlock Text="2. Qiymət və Stok Məlumatları" Style="{StaticResource SectionTitle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Alış qiyməti (AZN) *" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="PurchasePriceText" Text="0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Satış qiyməti (AZN) *" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="SalePriceText" Text="0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Minimum stok" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="MinStockText" Text="0"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,24,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Son maya dəyəri" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="LastCostText" Text="0.00" IsEnabled="False" Background="#F8FAFC"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Orta maya dəyəri" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="AverageCostText" Text="0.00" IsEnabled="False" Background="#F8FAFC"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Orta satış qiyməti" Style="{StaticResource Label}"/>
                                    <TextBox Text="0.00" IsEnabled="False" Background="#F8FAFC"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="0.75*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="0.95*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <TextBlock Text="3. Vergi və Gömrük Məlumatları" Style="{StaticResource SectionTitle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <CheckBox x:Name="IsVatApplicableCheck" Content="ƏDV tətbiq olunur" IsChecked="True"/>

                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="ƏDV faizi (%)" Style="{StaticResource Label}" VerticalAlignment="Center" Margin="0"/>
                                        <TextBox x:Name="VatRateText" Grid.Column="1" Text="18"/>
                                    </Grid>

                                    <CheckBox x:Name="IsPurchasePriceVatIncludedCheck"
                                              Content="Alış qiyməti ƏDV daxildir"
                                              IsChecked="True"
                                              Margin="0,10,0,0"/>

                                    <CheckBox x:Name="IsVatRecoverableCheck"
                                              Content="ƏDV əvəzləşdirilir"
                                              IsChecked="True"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <CheckBox x:Name="IsExciseApplicableCheck" Content="Aksiz tətbiq olunur"/>
                                    <CheckBox x:Name="IsImportTaxExemptCheck"
                                              Content="İdxal vergisindən azaddır"
                                              Margin="0,14,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <TextBlock Text="4. Ölçü və Çəki Məlumatları" Style="{StaticResource SectionTitle}"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Çəki (kg)" Style="{StaticResource Label}" VerticalAlignment="Center" Margin="0"/>
                                <TextBox x:Name="WeightText" Grid.Column="1" Text="0"/>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Həcm (m³)" Style="{StaticResource Label}" VerticalAlignment="Center" Margin="0"/>
                                <TextBox x:Name="VolumeText" Grid.Column="1" Text="0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <TextBlock Text="5. Digər Məlumatlar" Style="{StaticResource SectionTitle}"/>

                            <TextBlock Text="Xüsusiyyət dəsti" Style="{StaticResource Label}"/>
                            <ComboBox x:Name="AttributeSetCombo" Margin="0,0,0,12"/>

                            <TextBlock Text="Qeyd" Style="{StaticResource Label}"/>
                            <TextBox x:Name="NoteText"
                                     Height="48"
                                     Padding="10"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="145"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="6. Məhsul Xüsusiyyətləri" Style="{StaticResource SectionTitle}"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="AttributeDefinitionCombo"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectionChanged="AttributeDefinitionCombo_SelectionChanged"/>

                                <ComboBox x:Name="AttributeValueCombo"
                                          Grid.Column="2"
                                          DisplayMemberPath="Value"
                                          SelectedValuePath="Id"
                                          IsEnabled="False"/>

                                <Button Grid.Column="4"
                                        Content="+ Yeni Xüsusiyyət"
                                        Style="{StaticResource BlueButton}"
                                        Click="AddAttribute_Click"/>

                                <Button Grid.Column="6"
                                        Content="Sil"
                                        Style="{StaticResource DangerButton}"
                                        Click="RemoveAttribute_Click"/>
                            </Grid>

                            <DataGrid x:Name="AttributesGrid" Grid.Row="4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Atribut Adı" Binding="{Binding DefinitionName}" Width="*"/>
                                    <DataGridTextColumn Header="Dəyər" Binding="{Binding Value}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="145"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="7. Məhsul Vergi Qaydaları" Style="{StaticResource SectionTitle}"/>

                            <DataGrid x:Name="ProductTaxesGrid" Grid.Row="2">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Vergi Tipi" Binding="{Binding TaxType}" Width="*"/>
                                    <DataGridTextColumn Header="Faiz (%)" Binding="{Binding Rate}" Width="90"/>
                                    <DataGridCheckBoxColumn Header="Tətbiq olunur" Binding="{Binding IsApplicable}" Width="110"/>
                                    <DataGridCheckBoxColumn Header="Əvəzləşdirilə bilər" Binding="{Binding IsRecoverable}" Width="140"/>
                                    <DataGridTextColumn Header="Təsvir" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="8" Style="{StaticResource Card}" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="130"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="8. Stok Partiyaları - Mövcud Partiyalar"
                                   Style="{StaticResource SectionTitle}"/>

                        <DataGrid x:Name="StockBatchesGrid" Grid.Row="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Partiya No" Width="130"/>
                                <DataGridTextColumn Header="İstehsal Tarixi" Width="150"/>
                                <DataGridTextColumn Header="Son İstifadə Tarixi" Width="160"/>
                                <DataGridTextColumn Header="Miqdar" Width="100"/>
                                <DataGridTextColumn Header="Vahid" Width="100"/>
                                <DataGridTextColumn Header="Maya Dəyəri" Width="130"/>
                                <DataGridTextColumn Header="Yerləşdiyi Yer" Width="*"/>
                                <DataGridTextColumn Header="Qeyd" Width="160"/>
                                <DataGridTextColumn Header="Status" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <TextBlock x:Name="MessageText"
                           Grid.Row="10"
                           Text=""
                           Foreground="#15803D"
                           TextWrapping="Wrap"/>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1,1,0,0">
            <Grid Margin="18,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="SaveButton"
                            Content="💾  Yadda Saxla"
                            Width="145"
                            Style="{StaticResource PrimaryButton}"
                            Click="SaveButton_Click"/>

                    <Button Content="✕  İmtina Et"
                            Width="130"
                            Height="38"
                            Margin="12,0,0,0"
                            Background="White"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            Foreground="#334155"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>