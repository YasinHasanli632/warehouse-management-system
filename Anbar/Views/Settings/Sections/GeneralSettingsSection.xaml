<UserControl x:Class="Anbar.Views.Settings.Sections.GeneralSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <TextBlock Text="Ümumi Ayarlar"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="Sistem adı, şirkət məlumatları, default valyuta və əsas platforma davranışları."
                       Foreground="#64748B"
                       Margin="0,4,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="1. Şirkət və sistem məlumatları"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,14,12">
                                <TextBlock Text="Proqram adı" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBox x:Name="AppNameText"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Şirkət adı" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBox x:Name="CompanyNameText"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,14,12">
                                <TextBlock Text="VÖEN" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBox x:Name="CompanyVoenText"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Telefon" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBox x:Name="CompanyPhoneText"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,14,12">
                                <TextBlock Text="Ünvan" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBox x:Name="CompanyAddressText"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Default valyuta" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <ComboBox x:Name="DefaultCurrencyCombo"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2. Sistem davranışı"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <CheckBox x:Name="EnableCriticalStockWarningCheck"
                                  Content="Kritik stok xəbərdarlığı aktiv olsun"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="AllowNegativeStockCheck"
                                  Content="Mənfi stoka icazə verilsin"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="AutoShelfAssignCheck"
                                  Content="Rəf avtomatik təklif edilsin"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,12,0,0">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#1D4ED8"
                                       FontWeight="SemiBold"
                                       Text="Bu ayarlar sistemin ümumi davranışını idarə edir. Stok və qaimə modulları bu qaydaları ayrıca servislərdə tətbiq edəcək."/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>