<UserControl x:Class="Anbar.Views.Settings.Sections.InvoiceSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <TextBlock Text="Qaimə Ayarları"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="Giriş, çıxış, idxal, geri qaytarma, draft və təsdiq davranışlarını idarə edin."
                       Foreground="#64748B"
                       Margin="0,4,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="1. Əsas qaimə qaydaları"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Qaimə prefix" FontWeight="SemiBold"/>
                            <TextBox x:Name="InvoicePrefixText"/>
                        </StackPanel>

                        <CheckBox x:Name="LockConfirmedInvoiceCheck"
                                  Content="Təsdiqlənmiş qaimə kilidlənsin"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="RequireReturnReasonCheck"
                                  Content="Geri qaytarma səbəbi məcburi olsun"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="CopyBarcodeCheck"
                                  Content="Məhsul barkodu qaimə item-inə köçürülsün"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2. Giriş qaiməsi davranışı"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <CheckBox x:Name="RequireShelfSelectionCheck"
                                  Content="Giriş qaiməsində rəf seçimi məcburidir"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="RequireBatchReturnCheck"
                                  Content="Geri qaytarmada batch seçimi məcburidir"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,12,0,0">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#1D4ED8"
                                       FontWeight="SemiBold"
                                       Text="Rəf məcburidirsə StockIn confirm zamanı boş rəfli məhsul təsdiqlənməyəcək."/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="3. Qaimə lifecycle"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Draft"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"/>

                        <TextBlock Text="Qaimə yaradılır, məhsullar əlavə olunur, hələ stok dəyişmir."
                                   TextWrapping="Wrap"
                                   Foreground="#64748B"
                                   Margin="0,4,0,12"/>

                        <TextBlock Text="Confirmed"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"/>

                        <TextBlock Text="Stok artır, batch yaranır, supplier borcu və maya dəyəri hesablanır."
                                   TextWrapping="Wrap"
                                   Foreground="#64748B"
                                   Margin="0,4,0,12"/>

                        <TextBlock Text="Locked"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"/>

                        <TextBlock Text="Əgər kilidləmə aktivdirsə təsdiqlənmiş qaimə edit olunmur."
                                   TextWrapping="Wrap"
                                   Foreground="#64748B"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="4. Bu ayarlar harada işləyəcək?"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,14"/>

                    <UniformGrid Columns="3">
                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="InvoiceService" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock Text="CreateDraft, AddItem, Confirm, Lock logic." TextWrapping="Wrap" Foreground="#64748B" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="StockInView" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock Text="Rəf məcburiliyi, barcode copy, validation." TextWrapping="Wrap" Foreground="#64748B" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                            <StackPanel>
                                <TextBlock Text="InvoiceDetailView" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock Text="Confirmed qaimədə read-only davranış." TextWrapping="Wrap" Foreground="#64748B" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>