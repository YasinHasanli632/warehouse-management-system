<UserControl x:Class="Anbar.Views.Settings.Sections.NumberingSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Nömrələmə Ayarları"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="Qaimə prefix və gələcək sənəd nömrələmə formatları."
                       Foreground="#64748B"
                       Margin="0,4,0,18"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="1. Əsas qaimə nömrəsi"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,16"/>

                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,0,14,12">
                            <TextBlock Text="Giriş qaimə prefix" FontWeight="SemiBold"/>
                            <TextBox x:Name="InvoicePrefixText"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Nümunə nömrə" FontWeight="SemiBold"/>
                            <TextBox x:Name="PreviewText" IsReadOnly="True"/>
                        </StackPanel>
                    </UniformGrid>

                    <Border Background="#EFF6FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,12,0,0">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#1D4ED8"
                                   FontWeight="SemiBold"
                                   Text="Hazırda mövcud backend InvoicePrefix saxlayır. Çıxış, idxal, transfer prefix-ləri üçün gələcəkdə ayrıca DocumentNumberSetting əlavə etmək olar. İndi yeni entity yaratmırıq."/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="2. Gələcək enterprise formatlar"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,14"/>

                    <UniformGrid Columns="2">
                        <TextBlock Text="Giriş: IN-{YYYY}-{NNNNN}" Foreground="#334155" Margin="0,6"/>
                        <TextBlock Text="Çıxış: OUT-{YYYY}-{NNNNN}" Foreground="#334155" Margin="0,6"/>
                        <TextBlock Text="İdxal: IMP-{YYYY}-{NNNNN}" Foreground="#334155" Margin="0,6"/>
                        <TextBlock Text="Transfer: TRF-{YYYY}-{NNNNN}" Foreground="#334155" Margin="0,6"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>