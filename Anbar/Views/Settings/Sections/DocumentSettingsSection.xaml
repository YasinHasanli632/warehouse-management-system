<UserControl x:Class="Anbar.Views.Settings.Sections.DocumentSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Sənəd Ayarları"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="Qaiməyə əlavə ediləcək sənədlər, fayllar və invoice attachment davranışları."
                       Foreground="#64748B"
                       Margin="0,4,0,18"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="1. Sənəd davranışı"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,16"/>

                    <CheckBox Content="Giriş qaiməsində sənəd əlavə etmək aktiv olsun"
                              FontWeight="SemiBold"
                              IsChecked="True"
                              Margin="0,8,0,12"/>

                    <CheckBox Content="İdxal qaiməsində bəyannamə sənədi tələb olunsun"
                              FontWeight="SemiBold"
                              Margin="0,8,0,12"/>

                    <CheckBox Content="Excel import aktiv olsun"
                              FontWeight="SemiBold"
                              IsChecked="True"
                              Margin="0,8,0,12"/>

                    <Border Background="#EFF6FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,12,0,0">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#1D4ED8"
                                   FontWeight="SemiBold"
                                   Text="Bu section gələcək sənəd modulu üçündür. Hazırda yeni entity əlavə etmirik, sadəcə UI skeleton saxlayırıq."/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>