<UserControl x:Class="Anbar.Views.Settings.Sections.CostSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <TextBlock Text="Maya Dəyəri Ayarları"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="Əlavə xərclər, vergi, paylama üsulu və batch maya dəyəri hesablanmasını idarə edin."
                       Foreground="#64748B"
                       Margin="0,4,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="1. Maya hesablama"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <CheckBox x:Name="IncludeExpensesInCostCheck"
                                  Content="Əlavə xərclər maya dəyərinə daxil edilsin"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="AutoCalculateCostCheck"
                                  Content="Qaimə təsdiqində maya avtomatik hesablansın"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="RecalculateCostCheck"
                                  Content="Xərc dəyişəndə maya yenidən hesablansın"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="ExcludeZeroExpensesCheck"
                                  Content="0 məbləğli xərclər nəzərə alınmasın"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2. Paylama və satış"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Default xərc paylama üsulu" FontWeight="SemiBold"/>
                            <ComboBox x:Name="CostAllocationCombo"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Minimum marja faizi" FontWeight="SemiBold"/>
                            <TextBox x:Name="MinimumMarginText"/>
                        </StackPanel>

                        <CheckBox x:Name="SuggestSalePriceCheck"
                                  Content="Satış qiyməti təklif olunsun"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="LockCostAfterConfirmCheck"
                                  Content="Təsdiqlənmiş qaimədə maya kilidlənsin"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="3. Formula"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <Border Background="#ECFDF5"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,0,0,12">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#166534"
                                       FontWeight="Bold"
                                       Text="Maya = Alış qiyməti + Maya daxil xərclər + Vergilər - Endirimlər"/>
                        </Border>

                        <TextBlock Text="Bu formula CostCalculationService daxilində InvoiceItem və StockBatch maya dəyərinin hesablanmasında tətbiq olunacaq."
                                   TextWrapping="Wrap"
                                   Foreground="#64748B"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="4. Nümunə hesablama"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Alış" Foreground="#64748B"/>
                                <TextBlock Text="1000 AZN" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Xərc" Foreground="#64748B"/>
                                <TextBlock Text="+150 AZN" FontSize="20" FontWeight="Bold" Foreground="#166534"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Endirim" Foreground="#64748B"/>
                                <TextBlock Text="-30 AZN" FontSize="20" FontWeight="Bold" Foreground="#B91C1C"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="12" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Maya" Foreground="#1D4ED8"/>
                                <TextBlock Text="1120 AZN" FontSize="20" FontWeight="Bold" Foreground="#1D4ED8"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>