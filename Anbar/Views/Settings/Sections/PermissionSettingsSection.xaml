<UserControl x:Class="Anbar.Views.Settings.Sections.PermissionSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="İcazələr və Təhlükəsizlik"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="Admin şifrəsi və gələcək rol/icazə davranışları."
                       Foreground="#64748B"
                       Margin="0,4,0,18"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="1. Admin şifrəsi"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,16"/>

                    <UniformGrid Columns="3">
                        <StackPanel Margin="0,0,14,12">
                            <TextBlock Text="Köhnə şifrə" FontWeight="SemiBold"/>
                            <PasswordBox x:Name="OldPasswordBox" Height="38"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,14,12">
                            <TextBlock Text="Yeni şifrə" FontWeight="SemiBold"/>
                            <PasswordBox x:Name="NewPasswordBox" Height="38"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Yeni şifrə təkrar" FontWeight="SemiBold"/>
                            <PasswordBox x:Name="ConfirmPasswordBox" Height="38"/>
                        </StackPanel>
                    </UniformGrid>

                    <Button Content="Şifrəni dəyiş"
                            Width="160"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="2. Gələcək icazə qaydaları"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,14"/>

                    <CheckBox Content="Qaimə silmək yalnız admin üçün olsun" FontWeight="SemiBold" Margin="0,8,0,12"/>
                    <CheckBox Content="Maya dəyərini görmək yalnız admin üçün olsun" FontWeight="SemiBold" Margin="0,8,0,12"/>
                    <CheckBox Content="Stok düzəlişi yalnız admin üçün olsun" FontWeight="SemiBold" Margin="0,8,0,12"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>