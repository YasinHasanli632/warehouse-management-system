<UserControl x:Class="Anbar.Views.Settings.Sections.ImportSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <TextBlock Text="İdxal və Maya Dəyəri"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="İdxal qaiməsi, gömrük, broker, sığorta, freight, məzənnə və idxal xərc davranışları."
                       Foreground="#64748B"
                       Margin="0,4,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="1. Ümumi idxal qaydaları"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <CheckBox x:Name="EnableImportInvoiceCheck" Content="İdxal qaiməsi aktiv olsun" FontWeight="SemiBold" Margin="0,8,0,12"/>
                        <CheckBox x:Name="AutoOpenImportFieldsForForeignSupplierCheck" Content="Xarici təchizatçı seçiləndə idxal sahələri açılsın" FontWeight="SemiBold" Margin="0,8,0,12"/>
                        <CheckBox x:Name="RequireDeclarationNumberCheck" Content="Bəyannamə nömrəsi məcburidir" FontWeight="SemiBold" Margin="0,8,0,12"/>
                        <CheckBox x:Name="RequireExchangeRateCheck" Content="Məzənnə məcburidir" FontWeight="SemiBold" Margin="0,8,0,12"/>
                        <CheckBox x:Name="UseInvoiceDateExchangeRateCheck" Content="Qaimə tarixinin məzənnəsi istifadə olunsun" FontWeight="SemiBold" Margin="0,8,0,12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2. İdxal xərclərinin mayaya təsiri"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <CheckBox x:Name="IncludeCustomsDutyInCostCheck" Content="Gömrük rüsumu maya dəyərinə daxil edilsin" FontWeight="SemiBold" Margin="0,8,0,12"/>
                        <CheckBox x:Name="IncludeBrokerFeeInCostCheck" Content="Broker xərci maya dəyərinə daxil edilsin" FontWeight="SemiBold" Margin="0,8,0,12"/>
                        <CheckBox x:Name="IncludeInsuranceInCostCheck" Content="Sığorta maya dəyərinə daxil edilsin" FontWeight="SemiBold" Margin="0,8,0,12"/>
                        <CheckBox x:Name="IncludeTransportInCostCheck" Content="Daşıma / Freight maya dəyərinə daxil edilsin" FontWeight="SemiBold" Margin="0,8,0,12"/>

                        <Border Background="#EEF2FF"
                                BorderBrush="#C7D2FE"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,14,0,0">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#3730A3"
                                       FontWeight="Bold"
                                       Text="İdxal maya = Alış + Gömrük + Broker + Sığorta + Freight + Maya daxil vergilər - Endirimlər"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="3. İdxal form sahələri"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,14"/>

                    <DataGrid x:Name="ImportFieldsGrid"
                              Height="300"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sahə adı" Binding="{Binding DisplayName}" Width="2*"/>
                            <DataGridTextColumn Header="Tip" Binding="{Binding FieldType}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Görünsün" Binding="{Binding IsVisible}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Məcburi" Binding="{Binding IsRequired}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Qaimədə" Binding="{Binding ShowOnInvoice}" Width="*"/>
                            <DataGridTextColumn Header="Sıra" Binding="{Binding SortOrder}" Width="*"/>
                            <DataGridTextColumn Header="Placeholder" Binding="{Binding Placeholder}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>