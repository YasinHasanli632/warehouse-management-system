<UserControl x:Class="Anbar.Views.Settings.Sections.LocalPurchaseSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <TextBlock Text="Yerli Alış və Xərclər"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="Adi giriş qaiməsi, əlavə xərclər, ƏDV, xərc paylanması və maya davranışları."
                       Foreground="#64748B"
                       Margin="0,4,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="1. Ümumi yerli alış qaydaları"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <CheckBox x:Name="EnableLocalPurchaseInvoiceCheck"
                                  Content="Yerli alış qaiməsi aktiv olsun"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="EnableAdditionalExpensesCheck"
                                  Content="Əlavə xərclər aktiv olsun"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="AutoCalculateCostOnConfirmCheck"
                                  Content="Təsdiq zamanı maya avtomatik hesablansın"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="RecalculateBatchCostWhenExpenseChangesCheck"
                                  Content="Xərc dəyişəndə batch maya yenilənsin"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="IgnoreZeroAmountExpensesCheck"
                                  Content="0 məbləğli xərcləri nəzərə alma"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2. Vergi və xərc paylanması"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,14,12">
                                <TextBlock Text="Default xərc paylama üsulu" FontWeight="SemiBold"/>
                                <ComboBox x:Name="DefaultExpenseAllocationMethodCombo"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="ƏDV faizi" FontWeight="SemiBold"/>
                                <TextBox x:Name="VatPercentText"/>
                            </StackPanel>

                            <CheckBox x:Name="EnableVatCalculationCheck"
                                      Content="Yerli alışda ƏDV hesabla"
                                      FontWeight="SemiBold"
                                      Margin="0,8,14,12"/>

                            <CheckBox x:Name="PurchaseVatIncludedInPriceCheck"
                                      Content="Alış qiymətinə ƏDV daxildir"
                                      FontWeight="SemiBold"
                                      Margin="0,8,0,12"/>

                            <CheckBox x:Name="PurchaseVatIncludedInCostCheck"
                                      Content="ƏDV maya dəyərinə daxil edilsin"
                                      FontWeight="SemiBold"
                                      Margin="0,8,14,12"/>

                            <CheckBox x:Name="ShowVatSeparatelyInReportsCheck"
                                      Content="ƏDV hesabatda ayrıca görünsün"
                                      FontWeight="SemiBold"
                                      Margin="0,8,0,12"/>

                            <CheckBox x:Name="HidePassiveExpensesCheck"
                                      Content="Passiv xərc növlərini gizlət"
                                      FontWeight="SemiBold"
                                      Margin="0,8,14,12"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="3. Yerli xərc növləri"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,14"/>

                    <DataGrid x:Name="ExpenseTypesGrid"
                              Height="300"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="*"/>
                            <DataGridCheckBoxColumn Header="StockIn" Binding="{Binding UseForStockIn}" Width="*"/>
                            <DataGridCheckBoxColumn Header="İdxal" Binding="{Binding UseForImport}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Maya daxil" Binding="{Binding AffectStockCost}" Width="*"/>
                            <DataGridTextColumn Header="Paylanma" Binding="{Binding DefaultAllocationMethod}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#FFFBEB"
                            BorderBrush="#FDE68A"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,14,0,0">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#92400E"
                                   FontWeight="SemiBold"
                                   Text="Qeyd: Burada xərc növləri hələ read-only göstərilir. Növbəti mərhələdə ExpenseTypeService ilə əlavə/edit/sil-passiv et funksiyasını bağlayacağıq."/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="4. Maya formulu"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,14"/>

                    <Border Background="#ECFDF5"
                            BorderBrush="#BBF7D0"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="18">
                        <TextBlock Text="Yerli maya = Alış məbləği + Maya daxil edilən əlavə xərclər + Maya daxil edilən vergilər - Endirimlər"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#166534"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>