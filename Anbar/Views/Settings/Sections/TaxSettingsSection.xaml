<UserControl x:Class="Anbar.Views.Settings.Sections.TaxSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <TextBlock Text="Vergi Ayarları"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="ƏDV, mənfəət vergisi, sadələşdirilmiş vergi və idxal vergi davranışları."
                       Foreground="#64748B"
                       Margin="0,4,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="1. ƏDV"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Vergi rejimi" FontWeight="SemiBold"/>
                            <ComboBox x:Name="TaxRegimeCombo"/>
                        </StackPanel>

                        <CheckBox x:Name="EnableVatCheck" Content="ƏDV aktivdir" FontWeight="SemiBold" Margin="0,8,0,12"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="ƏDV faizi" FontWeight="SemiBold"/>
                            <TextBox x:Name="VatPercentText"/>
                        </StackPanel>

                        <CheckBox x:Name="PurchasePricesIncludeVatCheck" Content="Alış qiyməti ƏDV daxil qəbul edilsin" FontWeight="SemiBold" Margin="0,8,0,12"/>
                        <CheckBox x:Name="VatRecoverableCheck" Content="ƏDV əvəzləşdirilə biləndir" FontWeight="SemiBold" Margin="0,8,0,12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2. Mənfəət / Sadələşdirilmiş"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <CheckBox x:Name="EnableProfitTaxCheck" Content="Mənfəət vergisi aktivdir" FontWeight="SemiBold" Margin="0,8,0,12"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Mənfəət vergisi faizi" FontWeight="SemiBold"/>
                            <TextBox x:Name="ProfitTaxPercentText"/>
                        </StackPanel>

                        <CheckBox x:Name="EnableSimplifiedTaxCheck" Content="Sadələşdirilmiş vergi aktivdir" FontWeight="SemiBold" Margin="0,8,0,12"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Sadələşdirilmiş vergi faizi" FontWeight="SemiBold"/>
                            <TextBox x:Name="SimplifiedTaxPercentText"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="3. İdxal vergi mayası"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <CheckBox x:Name="IncludeImportVatInCostCheck" Content="İdxal ƏDV-si maya dəyərinə daxil edilsin" FontWeight="SemiBold" Margin="0,8,0,12"/>
                        <CheckBox x:Name="IncludeCustomsDutyInCostCheck" Content="Gömrük rüsumu maya dəyərinə daxil edilsin" FontWeight="SemiBold" Margin="0,8,0,12"/>
                        <CheckBox x:Name="IncludeExciseInCostCheck" Content="Aksiz maya dəyərinə daxil edilsin" FontWeight="SemiBold" Margin="0,8,0,12"/>

                        <Border Background="#F0FDF4"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,14,0,0">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#166534"
                                       FontWeight="SemiBold"
                                       Text="Vergi mayaya daxil edilirsə CostCalculationService həmin məbləği məhsulun batch maya dəyərinə paylamalıdır."/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>