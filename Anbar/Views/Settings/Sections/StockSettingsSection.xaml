<UserControl x:Class="Anbar.Views.Settings.Sections.StockSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <TextBlock Text="Stok Ayarları"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>

            <TextBlock Text="Stok hərəkəti, FIFO, batch, mənfi stok və rəf tutumu qaydalarını idarə edin."
                       Foreground="#64748B"
                       Margin="0,4,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="1. Stok davranışı"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <CheckBox x:Name="PreventNegativeStockCheck"
                                  Content="Mənfi stok bloklansın"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="CheckShelfCapacityCheck"
                                  Content="Rəf tutumu yoxlanılsın"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="BlockPassiveProductCheck"
                                  Content="Passiv məhsul qaiməyə düşməsin"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <Border Background="#F0FDF4"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,14,0,0">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#166534"
                                       FontWeight="SemiBold"
                                       Text="Bu qaydalar StockService-də IncreaseShelfStock, DecreaseShelfStock və TransferStock əməliyyatlarında tətbiq olunacaq."/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2. FIFO və Batch"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   Margin="0,0,0,16"/>

                        <CheckBox x:Name="EnableFifoCheck"
                                  Content="FIFO aktivdir"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <CheckBox x:Name="AutoCreateBatchCheck"
                                  Content="Girişdə batch avtomatik yaransın"
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,12"/>

                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,14,0,0">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#1D4ED8"
                                       FontWeight="SemiBold"
                                       Text="FIFO aktivdirsə çıxış qaiməsində ən köhnə batch-lər birinci istifadə olunmalıdır. Girişdə isə təsdiq zamanı batch avtomatik yaranacaq."/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="3. Real biznes təsiri"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,14"/>

                    <UniformGrid Columns="3">
                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="StockIn" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock Text="Mal daxil olanda shelf stock artır, batch yaranır, capacity yoxlanır." TextWrapping="Wrap" Foreground="#64748B" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="StockOut" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock Text="Mal çıxanda FIFO və mənfi stok qaydası tətbiq olunur." TextWrapping="Wrap" Foreground="#64748B" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Transfer" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock Text="Refdən-refə transferdə həm çıxış, həm giriş tərəfi yoxlanır." TextWrapping="Wrap" Foreground="#64748B" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>