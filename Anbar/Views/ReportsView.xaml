<UserControl x:Class="Anbar.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7FB">

    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="22"
                BorderBrush="#E5E7EB"
                BorderThickness="1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Hesabatlar"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>

                    <TextBlock Text="Giriş və çıxış qaimələrini filterlə, cədvəldə bax və EPPlus ilə Excel-ə çıxar."
                               Foreground="#64748B"
                               FontSize="13"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Button Content="Yenilə"
                        Width="110"
                        Height="38"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#EAF1FF"
                        Foreground="#1E3A8A"
                        BorderBrush="#BFDBFE"
                        FontWeight="SemiBold"
                        Click="Refresh_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="145"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="145"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Başlanğıc" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DatePicker x:Name="FromDatePicker" Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Son tarix" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DatePicker x:Name="ToDatePicker" Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Qaimə tipi" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox x:Name="TypeCombo" Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="6">
                    <TextBlock Text="Status" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ComboBox x:Name="StatusCombo" Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="8">
                    <TextBlock Text="Axtarış" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox x:Name="SearchText"
                             Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="10" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Axtar"
                            Width="90"
                            Height="36"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="Search_Click"/>

                    <Button Content="Excel"
                            Width="90"
                            Height="36"
                            Margin="8,0,0,0"
                            Background="#16A34A"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="ExportExcel_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="White" CornerRadius="12" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Qaimə sayı" Foreground="#64748B" FontWeight="SemiBold"/>
                        <TextBlock x:Name="InvoiceCountText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Məhsul sətri" Foreground="#64748B" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ItemCountText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#2563EB"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Dövriyyə" Foreground="#64748B" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TotalAmountText" Text="0.00 AZN" FontSize="24" FontWeight="Bold" Foreground="#B45309"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Background="White" CornerRadius="12" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Net qazanc" Foreground="#64748B" FontWeight="SemiBold"/>
                        <TextBlock x:Name="DebtAmountText" Text="0.00 AZN" FontSize="24" FontWeight="Bold" Foreground="#DC2626"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="18" BorderBrush="#E5E7EB" BorderThickness="1">
                <DataGrid x:Name="ReportGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          RowHeight="38">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Qaimə №" Binding="{Binding InvoiceNumber}" Width="135"/>
                        <DataGridTextColumn Header="Tarix" Binding="{Binding InvoiceDateText}" Width="135"/>
                        <DataGridTextColumn Header="Tip" Binding="{Binding TypeText}" Width="80"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="105"/>
                        <DataGridTextColumn Header="Tərəf" Binding="{Binding PartyName}" Width="160"/>
                        <DataGridTextColumn Header="Məhsul" Binding="{Binding ProductName}" Width="220"/>
                        <DataGridTextColumn Header="Kateqoriya" Binding="{Binding CategoryName}" Width="150"/>
                        <DataGridTextColumn Header="Xüsusiyyətlər" Binding="{Binding AttributesText}" Width="280"/>
                        <DataGridTextColumn Header="Rəf" Binding="{Binding ShelfCode}" Width="90"/>
                        <DataGridTextColumn Header="Miqdar" Binding="{Binding Quantity, StringFormat={}{0:N2}}" Width="90"/>
                        <DataGridTextColumn Header="Qiymət" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="90"/>
                        <DataGridTextColumn Header="Sətir cəmi" Binding="{Binding LineTotal, StringFormat={}{0:N2}}" Width="100"/>
                        <DataGridTextColumn Header="Qaimə cəmi" Binding="{Binding InvoiceTotal, StringFormat={}{0:N2}}" Width="110"/>
                        <DataGridTextColumn Header="Borc" Binding="{Binding DebtAmount, StringFormat={}{0:N2}}" Width="95"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    Margin="0,14,0,0">

                <TextBlock x:Name="MessageText"
                           Text="Filter seçib axtarış edin."
                           Foreground="#64748B"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>