<UserControl x:Class="Anbar.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7FB">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="12" Padding="22" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Kateqoriyalar"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                    <TextBlock Text="Əsas kateqoriya, alt kateqoriya, ölçü vahidi və məhsul xüsusiyyətlərini idarə edin"
                               Foreground="#64748B"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <TextBox x:Name="SearchText"
                         Grid.Column="1"
                         Height="38"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="#CBD5E1"
                         BorderThickness="1"
                         TextChanged="SearchText_TextChanged"/>

                <Button Grid.Column="3"
                        Content="Yeni kateqoriya"
                        Height="38"
                        Padding="18,0"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="NewCategory_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="460"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="12"
                    Padding="18"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <DataGrid x:Name="CategoriesGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionChanged="CategoriesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kateqoriya" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Tip" Binding="{Binding TypeText}" Width="95"/>
                        <DataGridTextColumn Header="Ana kateqoriya" Binding="{Binding ParentName}" Width="150"/>
                        <DataGridTextColumn Header="Ölçü vahidi" Binding="{Binding DefaultUnitText}" Width="135"/>
                        <DataGridTextColumn Header="Alt say" Binding="{Binding SubCount}" Width="75"/>
                        <DataGridTextColumn Header="Məhsul say" Binding="{Binding ProductCount}" Width="90"/>
                        <DataGridTextColumn Header="Qeyd" Binding="{Binding Description}" Width="220"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="FormTitleText"
                                   Text="Yeni kateqoriya"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Kateqoriya tipi" Foreground="#475569" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CategoryTypeCombo"
                                  Height="36"
                                  Margin="0,6,0,12"
                                  SelectionChanged="CategoryTypeCombo_SelectionChanged">
                            <ComboBoxItem Content="Əsas kateqoriya" Tag="Main"/>
                            <ComboBoxItem Content="Alt kateqoriya" Tag="Sub"/>
                        </ComboBox>

                        <TextBlock Text="Ana kateqoriya" Foreground="#475569" FontWeight="SemiBold"/>
                        <ComboBox x:Name="ParentCategoryCombo"
                                  Height="36"
                                  Margin="0,6,0,12"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"/>

                        <TextBlock Text="Kateqoriya adı" Foreground="#475569" FontWeight="SemiBold"/>
                        <TextBox x:Name="NameText"
                                 Height="36"
                                 Margin="0,6,0,12"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"/>

                        <!-- YENI: Kateqoriya üçün default ölçü vahidi -->
                        <TextBlock Text="Ölçü vahidi" Foreground="#475569" FontWeight="SemiBold"/>
                        <ComboBox x:Name="DefaultUnitCombo"
                                  Height="36"
                                  Margin="0,6,0,12"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"/>

                        <TextBlock Text="Qeyd" Foreground="#475569" FontWeight="SemiBold"/>
                        <TextBox x:Name="DescriptionText"
                                 Height="80"
                                 Margin="0,6,0,16"
                                 Padding="10"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>

                        <Button x:Name="SaveButton"
                                Content="Yadda saxla"
                                Height="40"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Click="SaveButton_Click"/>

                        <Button Content="Formanı təmizlə"
                                Height="38"
                                Margin="0,10,0,0"
                                Background="#EAF1FF"
                                Foreground="#1E3A8A"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                FontWeight="SemiBold"
                                Click="ClearButton_Click"/>

                        <Button x:Name="DeactivateButton"
                                Content="Kateqoriyanı passiv et"
                                Height="38"
                                Margin="0,10,0,0"
                                Background="#FEF2F2"
                                Foreground="#DC2626"
                                BorderBrush="#FECACA"
                                BorderThickness="1"
                                FontWeight="SemiBold"
                                IsEnabled="False"
                                Click="DeactivateButton_Click"/>

                        <Separator Margin="0,18,0,12"/>

                        <TextBlock Text="Kateqoriya xüsusiyyətləri"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"/>

                        <TextBlock Text="Burada seçilmiş kateqoriya üçün Rəng, Ölçü, Material kimi xüsusiyyətlər və dəyərlər idarə olunur. İstifadə olunmuş dəyər silinmir, sistem qoruyur."
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,12"/>

                        <TextBlock Text="Xüsusiyyət adı" Foreground="#475569" FontWeight="SemiBold"/>
                        <Grid Margin="0,6,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="AttributeDefinitionText"
                                     Height="36"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Məs: Rəng, Ölçü, Material"/>

                            <Button x:Name="AddOrUpdateDefinitionButton"
                                    Grid.Column="2"
                                    Content="Əlavə et"
                                    Height="36"
                                    Padding="12,0"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Click="AddOrUpdateDefinition_Click"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="Xüsusiyyəti redaktə et"
                                    Height="34"
                                    Background="#F8FAFC"
                                    Foreground="#334155"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    FontWeight="SemiBold"
                                    Click="EditDefinition_Click"/>

                            <Button Grid.Column="2"
                                    Content="Xüsusiyyəti sil/passiv et"
                                    Height="34"
                                    Background="#FEF2F2"
                                    Foreground="#DC2626"
                                    BorderBrush="#FECACA"
                                    BorderThickness="1"
                                    FontWeight="SemiBold"
                                    Click="DeleteDefinition_Click"/>
                        </Grid>

                        <TextBlock Text="Dəyər əlavə et / dəyiş" Foreground="#475569" FontWeight="SemiBold"/>
                        <Grid Margin="0,6,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="AttributeValueText"
                                     Height="36"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Məs: Ağ, Qara, 200sm, MDF"/>

                            <Button x:Name="AddOrUpdateValueButton"
                                    Grid.Column="2"
                                    Content="Dəyər əlavə et"
                                    Height="36"
                                    Padding="12,0"
                                    Background="#16A34A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Click="AddOrUpdateValue_Click"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="Dəyəri redaktə et"
                                    Height="34"
                                    Background="#F8FAFC"
                                    Foreground="#334155"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    FontWeight="SemiBold"
                                    Click="EditValue_Click"/>

                            <Button Grid.Column="2"
                                    Content="Dəyəri sil/passiv et"
                                    Height="34"
                                    Background="#FEF2F2"
                                    Foreground="#DC2626"
                                    BorderBrush="#FECACA"
                                    BorderThickness="1"
                                    FontWeight="SemiBold"
                                    Click="DeleteValue_Click"/>
                        </Grid>

                        <DataGrid x:Name="AttributesGrid"
                                  Height="190"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionChanged="AttributesGrid_SelectionChanged"
                                  Margin="0,0,0,12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="0"/>
                                <DataGridTextColumn Header="Xüsusiyyət" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Dəyərlər" Binding="{Binding ValuesText}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Seçilmiş xüsusiyyətin dəyərləri" Foreground="#475569" FontWeight="SemiBold"/>
                        <DataGrid x:Name="AttributeValuesGrid"
                                  Height="130"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionChanged="AttributeValuesGrid_SelectionChanged"
                                  Margin="0,6,0,12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="0"/>
                                <DataGridTextColumn Header="Dəyər" Binding="{Binding Value}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12"
                                Margin="0,4,0,0">
                            <TextBlock x:Name="MessageText"
                                       Text="Yeni kateqoriya əlavə edə bilərsiniz."
                                       TextWrapping="Wrap"
                                       Foreground="#64748B"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>