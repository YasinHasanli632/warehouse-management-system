<UserControl x:Class="Anbar.Views.InputInvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7FB">

    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" CornerRadius="12" Padding="22" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Giriş qaimələri"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>

                    <TextBlock Text="Təchizatçılardan daxil olan malların qaimələri"
                               Foreground="#64748B"
                               FontSize="13"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Button Content="Yenilə"
                        Width="110"
                        Height="36"
                        HorizontalAlignment="Right"
                        Background="#EAF1FF"
                        Foreground="#1E3A8A"
                        BorderBrush="#BFDBFE"
                        Click="Refresh_Click"/>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <DatePicker x:Name="FromDatePicker" Grid.Column="0"/>
                <DatePicker x:Name="ToDatePicker" Grid.Column="2"/>

                <ComboBox x:Name="StatusCombo"
                          Grid.Column="4"
                          Height="36"/>

                <TextBox x:Name="SearchText"
                         Grid.Column="6"
                         Height="36"
                         Padding="10,0"/>

                <StackPanel Grid.Column="8" Orientation="Horizontal">
                    <Button Content="Axtar"
                            Width="80"
                            Click="Search_Click"
                            Background="#2563EB"
                            Foreground="White"/>

                    <Button Content="Excel"
                            Width="80"
                            Margin="8,0,0,0"
                            Background="#16A34A"
                            Foreground="White"
                            Click="Export_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="4"
                Background="White"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DataGrid x:Name="InvoicesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="InvoicesGrid_SelectionChanged">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Qaimə №" Binding="{Binding InvoiceNumber}" Width="140"/>
                    <DataGridTextColumn Header="Tarix" Binding="{Binding InvoiceDateText}" Width="140"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="120"/>
                    <DataGridTextColumn Header="Təchizatçı" Binding="{Binding PartyName}" Width="*"/>
                    <DataGridTextColumn Header="Ümumi" Binding="{Binding TotalAmount}" Width="120"/>
                    <DataGridTextColumn Header="Borc" Binding="{Binding DebtAmount}" Width="120"/>
                </DataGrid.Columns>

            </DataGrid>
        </Border>
    </Grid>
</UserControl>