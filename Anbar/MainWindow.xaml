<Window x:Class="Anbar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anbar ERP / WMS"
        Height="860"
        Width="1480"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Window.Resources>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarSubButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarNavButtonStyle}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="22,1,10,1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="SidebarIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="274"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F172A">
            <DockPanel LastChildFill="True">

                <Border DockPanel.Dock="Top"
                        Height="82"
                        Padding="16,0"
                        Background="#111C33"
                        BorderBrush="#1E293B"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="36"
                                Height="36"
                                CornerRadius="10"
                                Background="#EFF6FF"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE7B8;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="17"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="10,0,0,0">
                            <TextBlock x:Name="LogoText"
                                       Text="ANBAR ERP"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="LogoSubText"
                                       Text="Warehouse Management"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Background="#1E293B"
                                BorderBrush="#334155"
                                Click="ToggleSidebar_Click">
                            <TextBlock x:Name="SidebarToggleIcon"
                                       Text="←"
                                       Foreground="White"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <Border DockPanel.Dock="Bottom"
                        Padding="12"
                        BorderBrush="#1E293B"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Border x:Name="AdminBox"
                                Background="#111827"
                                CornerRadius="12"
                                Padding="12"
                                Margin="0,0,0,10"
                                BorderBrush="#1F2937"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="30"
                                        Height="30"
                                        CornerRadius="15"
                                        Background="#2563EB">
                                    <TextBlock Text="A"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Admin"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="13"/>
                                    <TextBlock Text="Sistem idarəçisi"
                                               Foreground="#94A3B8"
                                               FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Button x:Name="LogoutButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Logout_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE8BB;"/>
                                <TextBlock x:Name="LogoutText"
                                           Text="Çıxış"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,12,0,12">

                        <TextBlock x:Name="SectionMainText"
                                   Text="ƏSAS"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="22,8,0,6"/>

                        <Button x:Name="DashboardButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Dashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE80F;"/>
                                <TextBlock x:Name="DashboardText"
                                           Text="Dashboard"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="InvoicesButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="InvoicesDropdown_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE8A5;"/>
                                    <TextBlock x:Name="InvoicesText"
                                               Text="Qaimələr"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock x:Name="InvoicesArrow"
                                           Grid.Column="1"
                                           Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="#94A3B8"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Button>

                        <StackPanel x:Name="InvoicesSubMenu" Visibility="Collapsed">

                            <Button x:Name="AllInvoicesButton"
                                    Style="{StaticResource SidebarSubButtonStyle}"
                                    Click="AllInvoices_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE8FD;"/>
                                    <TextBlock x:Name="AllInvoicesText"
                                               Text="Bütün qaimələr"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="InputInvoicesButton"
                                    Style="{StaticResource SidebarSubButtonStyle}"
                                    Click="InputInvoices_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE8AB;"/>
                                    <TextBlock x:Name="InputInvoicesText"
                                               Text="Giriş qaimələri"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="OutputInvoicesButton"
                                    Style="{StaticResource SidebarSubButtonStyle}"
                                    Click="OutputInvoices_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE8AC;"/>
                                    <TextBlock x:Name="OutputInvoicesText"
                                               Text="Çıxış qaimələri"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>

                        <TextBlock x:Name="SectionWarehouseText"
                                   Text="ANBAR ƏMƏLİYYATLARI"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="22,18,0,6"/>

                        <Button x:Name="WarehouseMapButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="WarehouseMap_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE707;"/>
                                <TextBlock x:Name="WarehouseMapText"
                                           Text="Anbar xəritəsi"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="WarehousesButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Warehouses_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE7EE;"/>
                                <TextBlock x:Name="WarehousesText"
                                           Text="Anbarlar"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="ShelvesButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Shelves_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE8F1;"/>
                                <TextBlock x:Name="ShelvesText"
                                           Text="Rəflər"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="StockInButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="StockIn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE896;"/>
                                <TextBlock x:Name="StockInText"
                                           Text="Mal girişi"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="StockOutButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="StockOut_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE898;"/>
                                <TextBlock x:Name="StockOutText"
                                           Text="Mal çıxışı"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="TransferButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Transfer_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE8B1;"/>
                                <TextBlock x:Name="TransferText"
                                           Text="Rəf transferi"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock x:Name="SectionMasterText"
                                   Text="MASTER DATA"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="22,18,0,6"/>

                        <Button x:Name="ProductsButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Products_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE8D7;"/>
                                <TextBlock x:Name="ProductsText"
                                           Text="Məhsullar"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="CategoriesButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Categories_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE8EC;"/>
                                <TextBlock x:Name="CategoriesText"
                                           Text="Kateqoriyalar"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="SuppliersButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Suppliers_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE77B;"/>
                                <TextBlock x:Name="SuppliersText"
                                           Text="Təchizatçılar"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="CustomersButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Customers_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE716;"/>
                                <TextBlock x:Name="CustomersText"
                                           Text="Müştərilər"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock x:Name="SectionAnalysisText"
                                   Text="ANALİTİKA"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="22,18,0,6"/>

                        <Button x:Name="ReportsButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Reports_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE9D2;"/>
                                <TextBlock x:Name="ReportsText"
                                           Text="Hesabatlar"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="SettingsButton"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="Settings_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SidebarIconStyle}" Text="&#xE713;"/>
                                <TextBlock x:Name="SettingsText"
                                           Text="Ayarlar"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="74"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    Padding="22,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="390"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText"
                                   Text="Dashboard"
                                   FontSize="21"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>

                        <TextBlock x:Name="PageSubtitleText"
                                   Text="Enterprise WMS / ERP iş paneli"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Height="38"
                            VerticalAlignment="Center"
                            Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="#94A3B8"
                                       VerticalAlignment="Center"/>

                            <TextBox x:Name="GlobalSearchBox"
                                     Grid.Column="1"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextBrush}"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     TextChanged="GlobalSearchBox_TextChanged"
                                     ToolTip="Qaimə, məhsul, barkod, rəf üzrə axtarış"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <Border Background="#F8FAFC"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10,7"
                                Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock x:Name="CurrentDateText"
                                           Text="--"
                                           Foreground="{StaticResource TextBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                                <TextBlock x:Name="ActiveModuleText"
                                           Text="Aktiv modul"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <Button Width="38"
                                Height="38"
                                Padding="0"
                                Style="{StaticResource SecondaryButtonStyle}">
                            <TextBlock Text="&#xE7F4;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Foreground="{StaticResource TextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Padding="22"
                    Background="{StaticResource BgBrush}">
                <ContentControl x:Name="MainContent"/>
            </Border>
        </Grid>
    </Grid>
</Window>